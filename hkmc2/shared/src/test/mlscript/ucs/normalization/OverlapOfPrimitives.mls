//│ >    else null
fun test(x, p) = if x is
  Int and p(x) then "foo"
  0 then "bar"
  else "qax"
//│ Desugared:
//│ >  if
//│ >    x is Int and
//│ >      let $scrut = p#666(x#666)
//│ >      $scrut is true then "foo"
//│ >    x is 0 then "bar"
//│ >    else "qax"

fun test(x, p) = if x is
  Str and p(x) then "foo"
  "lol" then "bar"
  else "qax"
//│ Desugared:
//│ >  if
//│ >    x is Str and
//│ >      let $scrut = p#666(x#666)
//│ >      $scrut is true then "foo"
//│ >    x is "lol" then "bar"
//│ >    else "qax"

test(0, _ => true)

